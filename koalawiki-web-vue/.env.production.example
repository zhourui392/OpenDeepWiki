# 生产环境配置示例
# 复制此文件为 .env.production.local 并修改为实际配置

# 后端 API 地址
# 开发环境：使用相对路径 /api（通过 Vite proxy 代理）
# 生产环境：使用完整地址，如 http://your-server-ip:18081/api
VITE_API_BASE_URL=http://localhost:18081/api

# 部署示例：
# 单机部署：VITE_API_BASE_URL=http://localhost:18081/api
# 远程部署：VITE_API_BASE_URL=http://192.168.1.100:18081/api
# 域名部署：VITE_API_BASE_URL=https://api.yourdomain.com/api
